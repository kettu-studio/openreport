# Función para ejecutar escaneo con Trivy
run_trivy_scan() {
  local directory="$1"
  local output_file="$2"
  
  echo -e "${BLUE}Ejecutando escaneo de Trivy en: $directory${NC}"
  
  # Ejecutar Trivy
  trivy fs --format json --output "$output_file" "$directory"
  
  # Verificar si el archivo de salida se creó correctamente
  if [ -f "$output_file" ] && [ -s "$output_file" ]; then
    echo -e "${GREEN}Escaneo de Trivy completado. Resultado guardado en: $output_file${NC}"
    return 0
  else
    echo -e "${RED}Error en el escaneo de Trivy. No se pudo crear el archivo de salida.${NC}"
    return 1
  fi
}

# Función para ejecutar escaneo con Gitleaks
run_gitleaks_scan() {
  local directory="$1"
  local output_file="$2"
  
  echo -e "${BLUE}Ejecutando escaneo de Gitleaks en: $directory${NC}"
  
  # Ejecutar Gitleaks
  gitleaks detect --source "$directory" --report-format json --report-path "$output_file"
  
  # Gitleaks puede devolver códigos de salida diferentes:
  # - 0: Sin secretos encontrados
  # - 1: Secretos encontrados (esto es exitoso para nosotros)
  # Verificar si el archivo de salida se creó correctamente
  if [ -f "$output_file" ] && [ -s "$output_file" ]; then
    echo -e "${GREEN}Escaneo de Gitleaks completado. Resultado guardado en: $output_file${NC}"
    return 0
  else
    echo -e "${RED}Error en el escaneo de Gitleaks. No se pudo crear el archivo de salida.${NC}"
    return 1
  fi
}

# Función para ejecutar escaneo con Syft
run_syft_scan() {
  local directory="$1"
  local output_file="$2"
  
  echo -e "${BLUE}Ejecutando escaneo de Syft en: $directory${NC}"
  
  # Ejecutar Syft
  syft packages "$directory" --output json --file "$output_file"
  
  # Verificar si el archivo de salida se creó correctamente
  if [ -f "$output_file" ] && [ -s "$output_file" ]; then
    echo -e "${GREEN}Escaneo de Syft completado. Resultado guardado en: $output_file${NC}"
    return 0
  else
    echo -e "${RED}Error en el escaneo de Syft. No se pudo crear el archivo de salida.${NC}"
    return 1
  fi
 }

# Función para subir reporte
upload_report() {
  local file="$1"
  local project="$2"
  local api_url="$3"
  
  echo -e "${BLUE}Subiendo reporte: $file${NC}"
  
  # Construye la URL completa
  local endpoint_url="${api_url}/api/projects/${project}/upload"
  
  # Realiza la petición POST con curl
  response=$(curl -s -X POST \
       -H "Content-Type: application/json" \
       --data-binary "@$file" \
       "$endpoint_url")
  
  # Verificar si la respuesta fue exitosa
  if [ $? -eq 0 ]; then
    # Extraer la URL del reporte de la respuesta JSON
    report_url=$(echo "$response" | grep -o '"reportUrl":"[^"]*"' | cut -d'"' -f4)
    
    if [ -n "$report_url" ]; then
      echo -e "${GREEN}Reporte subido: $report_url${NC}"
      return 0
    else
      echo -e "${YELLOW}Reporte subido exitosamente, pero no se pudo obtener la URL del reporte.${NC}"
      echo "Respuesta de la API: $response"
      return 0
    fi
  else
    echo -e "${RED}Error al subir el reporte.${NC}"
    echo "Respuesta de la API: $response"
    return 1
  fi
}

# Función para el comando scan
scan_command() {
  local directory="./"
  local project=""
  local api_url=""
  local scanners="trivy,gitleaks,syft" # Default scanners
  
  # Parsear los argumentos
  shift # Elimina "scan" del array de argumentos
  
  # El primer argumento es el directorio (opcional)
  if [ "$1" != "" ] && [[ "$1" != -* ]]; then
    directory="$1"
    shift
  fi
  
  while [ "$1" != "" ]; do
    case "$1" in
      -p | --project )
        shift
        project="$1"
        ;;
      --api )
        shift
        api_url="$1"
        ;;
      -s | --scanners )
        shift
        scanners="$1"
        ;;
      * )
        echo -e "${RED}Error: Argumento desconocido: $1${NC}"
        show_help
        exit 1
        ;;
    esac
    shift
  done
  
  # Validar que se hayan proporcionado los valores requeridos
  if [ -z "$project" ] || [ -z "$api_url" ]; then
    echo -e "${RED}Error: Faltan argumentos. Se requieren el proyecto y la URL de la API.${NC}"
    show_help
    exit 1
  fi
  
  # Validar que el directorio existe
  if [ ! -d "$directory" ]; then
    echo -e "${RED}Error: El directorio '$directory' no existe.${NC}"
    exit 1
  fi
  
  # Convertir la lista de scanners a un array y validar
  IFS=',' read -ra SCANNER_ARRAY <<< "$scanners"
  local valid_scanners=()
  local invalid_scanners=()
  
  for scanner in "${SCANNER_ARRAY[@]}"; do
    scanner=$(echo "$scanner" | tr '[:upper:]' '[:lower:]' | xargs) # Normalizar
    case "$scanner" in
      "trivy"|"gitleaks"|"syft")
        valid_scanners+=("$scanner")
        ;;
      *)
        invalid_scanners+=("$scanner")
        ;;
    esac
  done
  
  if [ ${#invalid_scanners[@]} -gt 0 ]; then
    echo -e "${RED}Error: Herramientas de escaneo no válidas: ${invalid_scanners[*]}${NC}"
    echo -e "${YELLOW}Herramientas válidas: trivy, gitleaks, syft${NC}"
    exit 1
  fi
  
  if [ ${#valid_scanners[@]} -eq 0 ]; then
    echo -e "${RED}Error: Debe especificar al menos una herramienta de escaneo válida.${NC}"
    exit 1
  fi
  
  echo -e "${GREEN}Iniciando escaneo de seguridad en: $directory${NC}"
  echo -e "${GREEN}Proyecto: $project${NC}"
  echo -e "${GREEN}API: $api_url${NC}"
  echo -e "${GREEN}Herramientas de escaneo: $scanners${NC}"
  echo -e "${BLUE}Archivos temporales: .openreport/${NC}"
  echo ""
  
  # Crear directorio temporal para los reportes
  local temp_dir=".openreport"
  local timestamp=$(date +%Y%m%d_%H%M%S)
  local trivy_output="$temp_dir/trivy-scan_$timestamp.json"
  local gitleaks_output="$temp_dir/gitleaks-scan_$timestamp.json"
  local syft_output="$temp_dir/syft-scan_$timestamp.json"
  
  # Crear directorio si no existe
  mkdir -p "$temp_dir"
  
  # Instalar herramientas si es necesario (solo las especificadas)
  local tools_available=0
  
  echo -e "${BLUE}Verificando herramientas de escaneo...${NC}"
  
  # Verificar Trivy solo si está en la lista
  if [[ " ${valid_scanners[*]} " =~ " trivy " ]]; then
    if install_trivy; then
      echo -e "${GREEN}✅ Trivy disponible${NC}"
      tools_available=$((tools_available + 1))
    else
      echo -e "${YELLOW}⚠️  Trivy no disponible - se omitirá este escaneo${NC}"
    fi
  fi
  
  # Verificar Gitleaks solo si está en la lista
  if [[ " ${valid_scanners[*]} " =~ " gitleaks " ]]; then
    if install_gitleaks; then
      echo -e "${GREEN}✅ Gitleaks disponible${NC}"
      tools_available=$((tools_available + 1))
    else
      echo -e "${YELLOW}⚠️  Gitleaks no disponible - se omitirá este escaneo${NC}"
    fi
  fi
  
  # Verificar Syft solo si está en la lista
  if [[ " ${valid_scanners[*]} " =~ " syft " ]]; then
    if install_syft; then
      echo -e "${GREEN}✅ Syft disponible${NC}"
      tools_available=$((tools_available + 1))
    else
      echo -e "${YELLOW}⚠️  Syft no disponible - se omitirá este escaneo${NC}"
    fi
  fi
  
  if [ $tools_available -eq 0 ]; then
    echo -e "${RED}❌ Error: No se pudo instalar ninguna de las herramientas especificadas.${NC}"
    exit 1
  fi
  
  echo ""
  
  # Ejecutar escaneos (solo los especificados y disponibles)
  local trivy_success=false
  local gitleaks_success=false
  local syft_success=false
  local scans_completed=0
  
  echo -e "${BLUE}Ejecutando escaneos de seguridad...${NC}"
  
  # Solo ejecutar Trivy si está especificado y disponible
  if [[ " ${valid_scanners[*]} " =~ " trivy " ]] && command -v trivy &> /dev/null; then
    if run_trivy_scan "$directory" "$trivy_output"; then
      trivy_success=true
      scans_completed=$((scans_completed + 1))
      echo -e "${GREEN}✅ Escaneo de Trivy completado${NC}"
    else
      echo -e "${YELLOW}⚠️  Escaneo de Trivy falló - se omitirá${NC}"
    fi
  fi
  
  # Solo ejecutar Gitleaks si está especificado y disponible
  if [[ " ${valid_scanners[*]} " =~ " gitleaks " ]] && command -v gitleaks &> /dev/null; then
    if run_gitleaks_scan "$directory" "$gitleaks_output"; then
      gitleaks_success=true
      scans_completed=$((scans_completed + 1))
      echo -e "${GREEN}✅ Escaneo de Gitleaks completado${NC}"
    else
      echo -e "${YELLOW}⚠️  Escaneo de Gitleaks falló - se omitirá${NC}"
    fi
  fi
  
  # Solo ejecutar Syft si está especificado y disponible
  if [[ " ${valid_scanners[*]} " =~ " syft " ]] && command -v syft &> /dev/null; then
    if run_syft_scan "$directory" "$syft_output"; then
      syft_success=true
      scans_completed=$((scans_completed + 1))
      echo -e "${GREEN}✅ Escaneo de Syft completado${NC}"
    else
      echo -e "${YELLOW}⚠️  Escaneo de Syft falló - se omitirá${NC}"
    fi
  fi
  
  echo ""
  
  if [ $scans_completed -eq 0 ]; then
    echo -e "${RED}❌ Error: Ningún escaneo se completó exitosamente.${NC}"
    exit 1
  fi
  
  # Subir reportes (solo los que se completaron exitosamente)
  echo -e "${BLUE}Subiendo reportes...${NC}"
  local upload_success=true
  local uploads_completed=0
  
  if [ "$trivy_success" = true ]; then
    if upload_report "$trivy_output" "$project" "$api_url"; then
      uploads_completed=$((uploads_completed + 1))
      echo -e "${GREEN}✅ Reporte de Trivy subido${NC}"
    else
      echo -e "${YELLOW}⚠️  Fallo al subir reporte de Trivy${NC}"
      upload_success=false
    fi
  fi
  
  if [ "$gitleaks_success" = true ]; then
    if upload_report "$gitleaks_output" "$project" "$api_url"; then
      uploads_completed=$((uploads_completed + 1))
      echo -e "${GREEN}✅ Reporte de Gitleaks subido${NC}"
    else
      echo -e "${YELLOW}⚠️  Fallo al subir reporte de Gitleaks${NC}"
      upload_success=false
    fi
  fi
  
  if [ "$syft_success" = true ]; then
    if upload_report "$syft_output" "$project" "$api_url"; then
      uploads_completed=$((uploads_completed + 1))
      echo -e "${GREEN}✅ Reporte de Syft subido${NC}"
    else
      echo -e "${YELLOW}⚠️  Fallo al subir reporte de Syft${NC}"
      upload_success=false
    fi
  fi
  
  # Limpiar archivos temporales del escaneo actual
  # rm -f "$trivy_output" "$gitleaks_output" "$syft_output"
  
  # Si la carpeta está vacía, eliminarla también
  if [ -z "$(ls -A "$temp_dir" 2>/dev/null)" ]; then
    rmdir "$temp_dir"
  fi
  
  echo ""
  echo -e "${GREEN}📊 Resumen del escaneo:${NC}"
  echo -e "   • Herramientas especificadas: ${#valid_scanners[@]}"
  echo -e "   • Escaneos completados: $scans_completed/$tools_available"
  echo -e "   • Reportes subidos: $uploads_completed/$scans_completed"
  
  if [ "$upload_success" = true ] && [ $uploads_completed -gt 0 ]; then
    echo -e "${GREEN}✅ Escaneo completado exitosamente.${NC}"
    if [ $uploads_completed -lt $scans_completed ]; then
      echo -e "${YELLOW}⚠️  Algunos reportes no se pudieron subir, pero el proceso continuó.${NC}"
    fi
  else
    echo -e "${RED}❌ No se pudo subir ningún reporte.${NC}"
    exit 1
  fi
}

# Función para el comando upload
upload_command() {
  local file=""
  local project=""
  local api_url=""

  # Parsear los argumentos
  shift # Elimina "upload" del array de argumentos
  while [ "$1" != "" ]; do
    case "$1" in
      -p | --project )
        shift
        project="$1"
        ;;
      --api )
        shift
        api_url="$1"
        ;;
      * )
        file="$1"
        ;;
    esac
    shift
  done

  # Validar que se hayan proporcionado todos los valores
  if [ -z "$file" ] || [ -z "$project" ] || [ -z "$api_url" ]; then
    echo -e "${RED}Error: Faltan argumentos. Se requieren el archivo, el proyecto y la URL de la API.${NC}"
    show_help
    exit 1
  fi

  # Validar si el archivo JSON existe
  if [ ! -f "$file" ]; then
    echo -e "${RED}Error: El archivo '$file' no existe.${NC}"
    exit 1
  fi

  # Subir el reporte
  if upload_report "$file" "$project" "$api_url"; then
    exit 0
  else
    exit 1
  fi
}

# La lógica principal de la CLI
main() {
  if [ "$1" == "upload" ]; then
    upload_command "$@"
  elif [ "$1" == "scan" ]; then
    scan_command "$@"
  else
    show_help
    exit 1
  fi
}

# Ejecutar la función principal
main "$@"
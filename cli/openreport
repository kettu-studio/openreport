#!/bin/bash

# openreport - CLI para subir resultados de reportes

# Colores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Función para mostrar la ayuda
show_help() {
  echo "Uso: openreport <comando> [opciones]"
  echo
  echo "Comandos:"
  echo "  upload <archivo> -p <proyecto> --api <url>"
  echo "    Sube un archivo JSON de resultados a un proyecto específico."
  echo "    <archivo>: Ruta al archivo JSON de resultados."
  echo "    -p, --project: Nombre del proyecto de destino."
  echo "    --api: URL base de la API (ej. https://openreport.kettu.tech)."
  echo
  echo "  scan <directorio> -p <proyecto> --api <url>"
  echo "    Escanea un directorio con Trivy, Gitleaks y Syft, y sube los reportes."
  echo "    <directorio>: Ruta al directorio a escanear (por defecto: ./)."
  echo "    -p, --project: Nombre del proyecto de destino."
  echo "    --api: URL base de la API (ej. https://openreport.kettu.tech)."
  echo
  echo "Ejemplos:"
  echo "  openreport upload results.json -p mi-proyecto --api https://openreport.kettu.tech"
  echo "  openreport scan ./ -p mi-proyecto --api https://openreport.kettu.tech"
  echo "  openreport scan /path/to/project -p proyecto-prod --api https://openreport.kettu.tech"
}

# Función para instalar Trivy
install_trivy() {
  echo -e "${BLUE}Instalando Trivy...${NC}"
  
  if command -v trivy &> /dev/null; then
    echo -e "${GREEN}Trivy ya está instalado.${NC}"
    return 0
  fi
  
  # Detectar el sistema operativo
  if [[ "$OSTYPE" == "linux-gnu"* ]]; then
    # Linux
    curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b /usr/local/bin v0.48.0
  elif [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS
    if command -v brew &> /dev/null; then
      brew install trivy
    else
      echo -e "${RED}Error: Homebrew no está instalado. Instala Homebrew primero.${NC}"
      return 1
    fi
  else
    echo -e "${RED}Error: Sistema operativo no soportado. Instala Trivy manualmente.${NC}"
    return 1
  fi
  
  if command -v trivy &> /dev/null; then
    echo -e "${GREEN}Trivy instalado correctamente.${NC}"
    return 0
  else
    echo -e "${RED}Error: No se pudo instalar Trivy.${NC}"
    return 1
  fi
}

